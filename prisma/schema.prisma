// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

// prisma/schema.prisma
datasource db {
  provider  = "postgresql"
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  balance        Float    @default(0)
  profilePicture String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outgoingTransactions Transaction[] @relation("UserTransactionsSent")
  incomingTransactions Transaction[] @relation("UserTransactionsReceived")


  ticketsCreated ticket[]

  userTicketConnects UserTicketConnect[]

  @@map("user")
}

model UserTicketConnect {
  userId    String
  ticketId  String
  userMarkedComplete Boolean  @default(false)
  acceptedByAuthor Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  ticket    ticket   @relation(fields: [ticketId], references: [id])

  @@id([userId, ticketId])
  @@map("user_ticket_connect")
}

model Transaction {
  id                  String   @id @default(cuid())
  amount              Float
  userId              String
  receiverId          String
  user                User     @relation("UserTransactionsSent", fields: [userId], references: [id])
  receiver            User     @relation("UserTransactionsReceived", fields: [receiverId], references: [id])
  createdAt           DateTime @default(now())

  @@map("transactions")
}

model ticket {
  id        String   @id @default(cuid())
  title     String
  content   String
  userId    String
  reward    Float
  user      User     @relation(fields: [userId], references: [id])
  maxParticipants Int
  maxFinishers Int
  createdAt DateTime @default(now())

  userTicketConnects UserTicketConnect[]

  @@map("tickets")
}