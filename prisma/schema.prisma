// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  balance   Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outgoingTransactions Transaction[] @relation("UserTransactionsSent")
  incomingTransactions Transaction[] @relation("UserTransactionsReceived")


  ticketsCreated ticket[]

  ticketsAccepted ticket[] @relation("ticketCompetitors")
}

model Transaction {
  id                  String   @id @default(cuid())
  amount              Float
  userId              String
  receiverId          String
  user                User     @relation("UserTransactionsSent", fields: [userId], references: [id])
  receiver            User     @relation("UserTransactionsReceived", fields: [receiverId], references: [id])
  createdAt           DateTime @default(now())
}

model ticket {
  id        String   @id @default(cuid())
  title     String
  content   String
  userId    String
  reward    Float
  user      User     @relation(fields: [userId], references: [id])
  maxParticipants Int
  maxFinishers Int
  competitors User[] @relation("ticketCompetitors")
  createdAt DateTime @default(now())
}